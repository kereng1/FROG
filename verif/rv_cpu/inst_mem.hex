// =============================================================================
// RV32I Comprehensive Test Program
// =============================================================================
// Address | Hex       | Instruction             | Expected Result
// =============================================================================

// --- Test 1: Basic I-type ALU (ADDI) ---
00A00093 // 0x00: ADDI  x1,  x0,  10            -> x1 = 10
01400113 // 0x04: ADDI  x2,  x0,  20            -> x2 = 20  
FFF00193 // 0x08: ADDI  x3,  x0,  -1            -> x3 = -1 (0xFFFFFFFF)

// --- Test 2: R-type ALU Operations ---
002081B3 // 0x0C: ADD   x3,  x1,  x2            -> x3 = 10 + 20 = 30
40208233 // 0x10: SUB   x4,  x1,  x2            -> x4 = 10 - 20 = -10 (0xFFFFFFF6)
0020C2B3 // 0x14: XOR   x5,  x1,  x2            -> x5 = 10 ^ 20 = 30
0020E333 // 0x18: OR    x6,  x1,  x2            -> x6 = 10 | 20 = 30
0020F3B3 // 0x1C: AND   x7,  x1,  x2            -> x7 = 10 & 20 = 0
0020A433 // 0x20: SLT   x8,  x1,  x2            -> x8 = (10 < 20) = 1
0020B4B3 // 0x24: SLTU  x9,  x1,  x2            -> x9 = (10 <u 20) = 1

// --- Test 3: R-type Shift Operations ---
00209533 // 0x28: SLL   x10, x1,  x2            -> x10 = 10 << (20 & 31) = 10485760
0020D5B3 // 0x2C: SRL   x11, x1,  x2            -> x11 = 10 >> 20 = 0
4020D633 // 0x30: SRA   x12, x1,  x2            -> x12 = 10 >>> 20 = 0

// --- Test 4: I-type Shift Operations ---
00209693 // 0x34: SLLI  x13, x1,  2             -> x13 = 10 << 2 = 40
0020D713 // 0x38: SRLI  x14, x1,  2             -> x14 = 10 >> 2 = 2
4020D793 // 0x3C: SRAI  x15, x1,  2             -> x15 = 10 >>> 2 = 2

// --- Test 5: I-type Comparison & Logic ---
00A0A813 // 0x40: SLTI  x16, x1,  10            -> x16 = (10 < 10) = 0
00B0A893 // 0x44: SLTI  x17, x1,  11            -> x17 = (10 < 11) = 1
00A0B913 // 0x48: SLTIU x18, x1,  10            -> x18 = (10 <u 10) = 0
00A0C993 // 0x4C: XORI  x19, x1,  10            -> x19 = 10 ^ 10 = 0
00A0EA13 // 0x50: ORI   x20, x1,  10            -> x20 = 10 | 10 = 10
00A0FA93 // 0x54: ANDI  x21, x1,  10            -> x21 = 10 & 10 = 10

// --- Test 6: Upper Immediate Instructions ---
12345B37 // 0x58: LUI   x22, 0x12345            -> x22 = 0x12345000
00000B97 // 0x5C: AUIPC x23, 0                  -> x23 = PC = 0x5C

// --- Test 7: Store and Load ---
00302023 // 0x60: SW    x3,  0(x0)              -> MEM[0] = x3 (30)
00002C03 // 0x64: LW    x24, 0(x0)              -> x24 = MEM[0] = 30
00000013 // 0x68: NOP (ADDI x0, x0, 0)          -> Wait for load to complete

// --- Test 8: Load-Use Hazard Test ---
00402C83 // 0x6C: LW    x25, 4(x0)              -> x25 = MEM[4] (should trigger stall)
019C8D13 // 0x70: ADDI  x26, x25, 25            -> x26 = x25 + 25 (dependent on LW)

// --- Test 9: Branch Not Taken ---
00208463 // 0x74: BEQ   x1,  x2,  +8            -> NOT taken (10 != 20), continue
00100D93 // 0x78: ADDI  x27, x0,  1             -> x27 = 1 (executes)

// --- Test 10: Branch Taken (BEQ) ---
00108463 // 0x7C: BEQ   x1,  x1,  +8            -> TAKEN (10 == 10), skip next
00200E13 // 0x80: ADDI  x28, x0,  2             -> SKIPPED (flushed by branch)
00300E93 // 0x84: ADDI  x29, x0,  3             -> x29 = 3 (branch target)

// --- Test 11: Branch Taken (BNE) ---
00209463 // 0x88: BNE   x1,  x2,  +8            -> TAKEN (10 != 20), skip next
00400F13 // 0x8C: ADDI  x30, x0,  4             -> SKIPPED (flushed by branch)
00500F93 // 0x90: ADDI  x31, x0,  5             -> x31 = 5 (branch target)

// --- Test 12: JAL (Jump and Link) ---
00C000EF // 0x94: JAL   x1,  +12                -> x1 = 0x98 (PC+4), jump to 0xA0
00600093 // 0x98: ADDI  x1,  x0,  6             -> SKIPPED (flushed by JAL)
00700113 // 0x9C: ADDI  x2,  x0,  7             -> SKIPPED (flushed by JAL)
00800193 // 0xA0: ADDI  x3,  x0,  8             -> x3 = 8 (JAL target)

// --- Test 13: JALR (Jump and Link Register) ---
0B000213 // 0xA4: ADDI  x4,  x0,  0xB0          -> x4 = 176 (0xB0)
000202E7 // 0xA8: JALR  x5,  x4,  0             -> x5 = 0xAC (PC+4), jump to x4 (0xB0)
00900293 // 0xAC: ADDI  x5,  x0,  9             -> SKIPPED (flushed by JALR)
00A00313 // 0xB0: ADDI  x6,  x0,  10            -> x6 = 10 (JALR target)

// --- Test 14: BLT (Branch Less Than) ---
0020C463 // 0xB4: BLT   x1,  x2,  +8            -> Depends on x1 < x2 (signed)
00B00393 // 0xB8: ADDI  x7,  x0,  11            -> May execute or skip

// --- Infinite Loop (End of Program) ---
0000006F // 0xBC: JAL   x0,  0                  -> Jump to self (infinite loop)

// --- Padding with NOPs ---
00000013 // 0xC0: NOP
00000013 // 0xC4: NOP
00000013 // 0xC8: NOP
00000013 // 0xCC: NOP
